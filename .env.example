# Discord Message Archiver - Configuration
# Copy this file to ".env" and edit the values below.

# ─── Server Port ────────────────────────────────────────────────────────────────
PORT=5000

# ─── Concurrency Settings ───────────────────────────────────────────────────────
# WARNING: Raising these too high can trigger Discord rate limits / account bans.
# Recommended: CONCURRENT_CHANNELS=1, CONCURRENT_DOWNLOADS=5

CONCURRENT_CHANNELS=1
CONCURRENT_DOWNLOADS=5
